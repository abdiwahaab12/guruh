FLASK_ENV=development

SECRET_KEY=local-dev-only-not-for-production

DATABASE_ENABLED=true

# Local MySQL (XAMPP / MariaDB / MySQL 8)
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/guruh_construction?charset=utf8mb4

PORT=5000

ADMIN_EMAIL=admin@guruh.com
ADMIN_PASSWORD=GuruhAdmin2026!
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

SESSION_IDLE_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_RESET_EXPIRY_HOURS=1
PASSWORD_MIN_LENGTH=8

MEDIA_UPLOAD_ROOT=uploads
MEDIA_MAX_FILE_SIZE=20971520
MEDIA_MAX_BATCH=20
